# === Python Environment ===
venv/
.venv/
env/
ENV/
pyvenv.cfg
*.pyc
*.pyo
*.pyd
__pycache__/

# === Scrapy Specific ===
.scrapy/
crawls/
logs/
*.log

# === Local Data & Database Storage ===
# Ignore local database files to prevent committing sensitive or raw datasets
dbs/
*.db
*.sqlite
*.sqlite3

# Ignore required raw output data formats (JSON, CSV, XML)
# They should be generated dynamically, not stored in git
output/
*.json
*.csv
*.xml

# === IDE & OS Files ===
.vscode/
.idea/
.DS_Store
Thumbs.db

# === Deployment & Containerization ===
# Ignore local build artifacts while keeping Dockerfile and scrapyd.conf
build/
eggs/
*.egg-info/
project.egg-info/
